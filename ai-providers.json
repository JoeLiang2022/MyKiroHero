{
  "version": "1.0.0",
  "lastUpdated": "2026-02-09",
  "providers": [
    {
      "id": "gemini",
      "name": "Google Gemini",
      "website": "https://aistudio.google.com/apikey",
      "envKey": "GEMINI_API_KEY",
      "keyPattern": "^AIza[0-9A-Za-z_-]{35}$",
      "freeTier": {
        "available": true,
        "note": "Free API key at aistudio.google.com/apikey (rate limited)"
      },
      "capabilities": ["image", "tts", "stt"],
      "mcpServer": {
        "type": "python",
        "command": "uvx",
        "args": ["gemini-gen-mcp"],
        "note": "ServiceStack gemini-gen-mcp: image generation + TTS. STT via Gemini API directly (no MCP server needed)",
        "envMapping": {
          "GEMINI_API_KEY": "GEMINI_API_KEY"
        }
      },
      "models": [
        {
          "id": "gemini-3-pro-image-preview",
          "name": "Gemini 3 Pro Image Preview (Nano Banana Pro)",
          "capability": "image",
          "default": true,
          "status": "preview",
          "note": "Highest quality image generation, up to 4K, multi-image fusion"
        },
        {
          "id": "gemini-2.5-flash-image",
          "name": "Gemini 2.5 Flash Image (Nano Banana)",
          "capability": "image",
          "default": false,
          "status": "stable",
          "note": "Fast and efficient, optimized for high-volume low-latency"
        },
        {
          "id": "gemini-2.5-pro-preview-tts",
          "name": "Gemini 2.5 Pro Preview TTS",
          "capability": "tts",
          "default": true,
          "status": "preview",
          "note": "Highest quality TTS, single + multi-speaker, 70+ languages"
        },
        {
          "id": "gemini-2.5-flash-preview-tts",
          "name": "Gemini 2.5 Flash Preview TTS",
          "capability": "tts",
          "default": false,
          "status": "preview",
          "note": "Fast TTS, single + multi-speaker, 70+ languages"
        },
        {
          "id": "gemini-3-flash-preview",
          "name": "Gemini 3 Flash Preview",
          "capability": "stt",
          "default": true,
          "status": "preview",
          "note": "Multimodal audio transcription, fast and efficient"
        },
        {
          "id": "gemini-2.5-flash",
          "name": "Gemini 2.5 Flash",
          "capability": "stt",
          "default": false,
          "status": "stable",
          "note": "Stable multimodal audio transcription"
        }
      ]
    },
