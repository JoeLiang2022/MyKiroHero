# MyKiroHero Environment Config / 環境設定範例
# Copy this file to .env and edit / 複製此檔案為 .env 並修改

# ============================================================
# 🌐 General Settings / 通用設定
# ============================================================

# Language (zh or en) / 語言設定
LANGUAGE=en

# AI reply prefix (identifies AI messages, prevents loops)
# AI 回覆前綴（識別 AI 訊息，避免迴圈）
AI_PREFIX=▸ *🤖 AI Assistant :*

# Gateway server port / Gateway 伺服器 port
# 'auto' = system assigns available port / 自動分配空閒 port
GATEWAY_PORT=auto

# Message splitting / 訊息分段設定
MESSAGE_MAX_LENGTH=1500
MESSAGE_SPLIT_DELAY=500

# Fragment message handling / 碎片訊息處理
# scoreThreshold: completeness score threshold (> value = complete message)
FRAGMENT_SCORE_THRESHOLD=0.6
# collectTimeout: ms to wait after last fragment before dispatch
FRAGMENT_COLLECT_TIMEOUT=3000
# maxMessages: max fragments to collect
FRAGMENT_MAX_MESSAGES=3
# maxWait: max total wait from first fragment (ms)
FRAGMENT_MAX_WAIT=7000

# Error notification: notify user when AI doesn't respond (true/false)
ERROR_NOTIFICATION=true

# Heartbeat config path / Heartbeat 設定檔路徑
HEARTBEAT_PATH=./.kiro/steering/HEARTBEAT.md

# Steering files path (AI personality config) / Steering 檔案路徑
STEERING_PATH=./.kiro/steering

# ============================================================
# 🔷 IDE Settings / IDE 專屬設定
# ============================================================

# IDE type (selects handler) / IDE 類型
# Options: kiro, cursor, windsurf, generic
IDE_TYPE=kiro

# IDE REST API port (for message forwarding) / IDE REST API port
IDE_REST_PORT=55139

# ============================================================
# 👤 User Settings (filled during onboarding) / 使用者設定
# ============================================================

# Your WhatsApp chatId (for scheduled reminders)
# Format: 886912345678@c.us / 留空 = onboarding 時設定
OWNER_CHAT_ID=

# ============================================================
# 🔌 Optional Features / 選配功能
# ============================================================

# WhatsApp Chrome headless mode (default: false = show QR window)
# Set to 'true' for headless server deployments
WA_HEADLESS=

# Soul & Memory backup repo (GitHub)
MEMORY_REPO=
GITHUB_TOKEN=

# Default weather location (leave empty if not needed)
DEFAULT_LOCATION=

# ============================================================
# 📋 Task Dispatch Settings / 任務分派設定
# ============================================================

# Task output directory (default: temp/tasks)
# TASK_OUTPUT_DIR=temp/tasks

# Worker mode (main = primary Kiro, worker = Worker Kiro)
# WORKER_MODE=main

# ============================================================
# 🤖 External AI Providers (optional) / 外部 AI 供應商
# ============================================================
# Use: node install.js --manage-ai / 或手動填入

# Enabled providers (comma-separated) / 已啟用的 provider
# Options: gemini, openai, elevenlabs, stability, xai
AI_PROVIDERS=

# API Keys (fill only the ones you use)
GEMINI_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
XAI_API_KEY=

# Selected models (format: provider:modelId, empty = default)
AI_MODEL_IMAGE=
AI_MODEL_TTS=
AI_MODEL_STT=

# STT Provider (speech-to-text) / 語音轉文字
# Options: gemini, openai, elevenlabs (empty = disabled)
STT_PROVIDER=

# Daily usage limits / 每日使用上限
AI_DAILY_LIMIT=100
AI_DAILY_COST_LIMIT=5.00
