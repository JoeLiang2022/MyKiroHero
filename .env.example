# MyKiroHero 環境設定範例
# 複製此檔案為 .env 並修改設定

# ============================================================
# 🌐 通用設定（任何 AI 工具都能用）
# ============================================================

# AI 回覆前綴（用來識別 AI 發的訊息，避免迴圈）
# 格式建議：*[名字]* emoji
AI_PREFIX=*[AI Assistant]* 🤖

# Gateway 伺服器 port
GATEWAY_PORT=3000

# 訊息分段設定
MESSAGE_MAX_LENGTH=1500
MESSAGE_SPLIT_DELAY=500

# 錯誤通知：AI 沒回應時自動通知使用者（true/false）
ERROR_NOTIFICATION=true

# Heartbeat 設定檔路徑
# 預設：專案根目錄的 HEARTBEAT.md
# Kiro 使用者可設為 .kiro/steering/HEARTBEAT.md
HEARTBEAT_PATH=./HEARTBEAT.md

# Steering 檔案路徑（AI 人格設定）
# Kiro: .kiro/steering/
# 其他 IDE: 可自訂
STEERING_PATH=./.kiro/steering

# ============================================================
# 🔷 IDE 專屬設定
# ============================================================

# IDE 類型（用於選擇對應的 handler）
# 支援: kiro, cursor, windsurf, generic
IDE_TYPE=kiro

# IDE REST API port（用於訊息轉發）
# Kiro/VS Code: vscode-rest-control extension (預設 55139)
# Cursor: 待定
# Windsurf: 待定
IDE_REST_PORT=55139
# 舊版相容：KIRO_REST_PORT 也可以用
# KIRO_REST_PORT=55139

# ============================================================
# 🔌 平台設定（選填）
# ============================================================

# Telegram Bot Token（如果要使用 Telegram）
# TELEGRAM_BOT_TOKEN=your_bot_token_here
